<style>
  /* The "Cartoon" Font - uses a clean, bubbly look */
  body {
    font-family: 'Comic Sans MS', 'Chalkboard SE', sans-serif;
    background-color: #f0f8ff; /* Light sky blue background */
    color: #333;
    padding: 20px;
  }

  /* Thick Black Outlines (Cel-Shading effect) */
  .container {
    background: white;
    border: 5px solid #000; /* Bold black border */
    border-radius: 25px;    /* Rounded "bubbly" corners */
    padding: 30px;
    box-shadow: 10px 10px 0px #000; /* "Hard" shadow for a 2D look */
    max-width: 800px;
    margin: auto;
  }

  /* Bright "Action" Buttons */
  .button {
    background-color: #ffcc00; /* Bright yellow */
    border: 4px solid #000;
    border-radius: 15px;
    padding: 15px 30px;
    font-weight: bold;
    font-size: 1.2rem;
    text-transform: uppercase;
    cursor: pointer;
    transition: transform 0.1s;
    display: inline-block;
    text-decoration: none;
    color: black;
  }

  /* Button "Pop" Animation when clicked */
  .button:active {
    transform: scale(0.95);
    background-color: #ff9900;
  }

  h1 {
    color: #ff4500; /* Vibrant Orange-Red */
    -webkit-text-stroke: 1.5px black; /* Outline on text */
    font-size: 3rem;
    text-align: center;
  }
</style>
